# RepoAgents live GitHub operations example environment

# Required for live GitHub REST mode.
export GITHUB_TOKEN=replace-me

# Optional: override the Codex command if needed.
export PATH="/opt/homebrew/bin:$PATH"

# Suggested repository-specific values:
# export REPOREPUBLIC_REPO="owner/name"

# Optional when running the bundled offline handoff rehearsal:
# export REPOREPUBLIC_PROJECT_ROOT=/path/to/RepoAgents
# export REPOREPUBLIC_HANDOFF_OUTPUT_DIR=.ai-repoagents/reports/ops/live-handoff-demo
