# RepoAgents sandbox rollout example environment

# Required for live GitHub REST mode, even during sandbox rehearsal.
export GITHUB_TOKEN=replace-me

# Optional: override the Codex command if needed.
export PATH="/opt/homebrew/bin:$PATH"

# Suggested sandbox values:
# export REPOREPUBLIC_REPO="owner/sandbox-repo"

# Optional when running the bundled rehearsal flow:
# export REPOREPUBLIC_PROJECT_ROOT=/path/to/RepoAgents
# export REPOREPUBLIC_SANDBOX_REPORT_ROOT=.ai-repoagents/reports/sandbox-rollout
# export REPOREPUBLIC_HANDOFF_OUTPUT_DIR=.ai-repoagents/reports/ops/sandbox-pr-ready
